# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file - it is already listed in .gitignore.
# All values below are placeholders only.

# --- Server ---
NODE_ENV=development
PORT=5000

# --- Database ---
# MongoDB Atlas connection string (or local mongodb://localhost:27017/english-friend-ai)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/english-friend-ai?retryWrites=true&w=majority

# --- JWT ---
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- OpenAI ---
OPENAI_API_KEY=sk-replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# --- Google Sign-In ---
GOOGLE_CLIENT_ID=replace-with-your-google-oauth-client-id

# --- CORS ---
# Comma-separated list of allowed origins, or "*" for all (dev only)
CORS_ORIGIN=http://localhost:3000
