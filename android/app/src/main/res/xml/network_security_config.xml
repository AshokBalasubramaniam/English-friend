        <pin-set expiration="2026-12-31">
            <pin digest="SHA-256">TODO_REPLACE_WITH_REAL_BASE64_SPKI_PIN=</pin>
            <pin digest="SHA-256">TODO_REPLACE_WITH_BACKUP_SPKI_PIN=</pin>
        </pin-set>
    </domain-config>
    -->
</network-security-config>
